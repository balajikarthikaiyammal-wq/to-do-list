# single_file_django_app.py

from django.conf import settings   # conf - configuration
from django.http import HttpResponse
from django.urls import path
from django.core.management import execute_from_command_line

# Step 1: Configure Django settings
settings.configure(
    DEBUG=True,
    ROOT_URLCONF=__name__,
    SECRET_KEY='abc123',
    ALLOWED_HOSTS=['*'],
)

# Step 2: Create view
def home(request):
    return HttpResponse("<h1>Hi, Welcome to Django!</h1>")

# Step 3: URL mapping
urlpatterns = [
    path('', home),
]

# Step 4: Run server
if __name__ == "__main__":
    execute_from_command_line(["manage.py", "runserver"])


