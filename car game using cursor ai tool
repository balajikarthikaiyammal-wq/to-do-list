"""
Advanced Pro Car Game - Full Stack (Python + HTML + CSS + JavaScript)
Run: python car_game_full.py
Open: http://127.0.0.1:5000
"""

from flask import Flask, render_template_string
import webbrowser
import threading

app = Flask(__name__)

HTML = '''
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🔥 TURBO STRIKE - Pro Car Shooter</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Rajdhani', sans-serif;
            overflow: hidden;
            background: #0a0a0f;
        }
        #game-container {
            width: 100vw;
            height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        }
        #game-canvas {
            border: 4px solid #e94560;
            border-radius: 8px;
            background: #1a1a2e;
            box-shadow: 0 0 60px rgba(233, 69, 96, 0.4);
        }
        #hud {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 800px;
            padding: 15px 20px;
            margin-bottom: 10px;
            background: rgba(0,0,0,0.6);
            border-radius: 12px;
            border: 2px solid #e94560;
        }
        #score, #lives, #ammo {
            font-family: 'Orbitron', monospace;
            font-size: 1.4rem;
            color: #e94560;
            font-weight: 700;
        }
        #hud span { color: #00fff5; }
        #controls {
            display: flex;
            gap: 12px;
            margin-top: 15px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .btn {
            padding: 14px 28px;
            font-family: 'Orbitron', monospace;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn:active { transform: scale(0.95); }
        .btn-move {
            background: linear-gradient(135deg, #e94560, #ff6b6b);
            color: white;
        }
        .btn-move:hover { box-shadow: 0 0 25px rgba(233,69,96,0.7); }
        .btn-shoot {
            background: linear-gradient(135deg, #00d9ff, #00fff5);
            color: #0a0a0f;
        }
        .btn-shoot:hover { box-shadow: 0 0 25px rgba(0,255,245,0.7); }
        #game-over, #start-screen {
            position: absolute;
            inset: 0;
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: rgba(0,0,0,0.9);
            z-index: 100;
        }
        #start-screen { display: flex; }
        #game-over h1, #start-screen h1 {
            font-family: 'Orbitron', monospace;
            font-size: 3.5rem;
            color: #e94560;
            text-shadow: 0 0 30px rgba(233,69,96,0.8);
            margin-bottom: 1rem;
        }
        #start-screen p, #game-over p {
            color: #00fff5;
            font-size: 1.2rem;
            margin-bottom: 2rem;
        }
        .start-btn {
            padding: 20px 50px;
            font-size: 1.5rem;
            background: linear-gradient(135deg, #e94560, #ff6b6b);
            color: white;
            border: none;
            border-radius: 15px;
            cursor: pointer;
            font-family: 'Orbitron', monospace;
            transition: all 0.2s;
        }
        .start-btn:hover { transform: scale(1.05); box-shadow: 0 0 40px rgba(233,69,96,0.6); }
    </style>
</head>
<body>
    <div id="game-container">
        <div id="hud">
            <div id="score">SCORE: <span>0</span></div>
            <div id="lives">LIVES: <span>3</span></div>
            <div id="ammo">AMMO: <span>50</span></div>
        </div>
        <canvas id="game-canvas" width="800" height="550"></canvas>
        <div id="controls">
            <button class="btn btn-move" id="left">◀ LEFT</button>
            <button class="btn btn-move" id="right">RIGHT ▶</button>
            <button class="btn btn-shoot" id="shoot">🔫 FIRE</button>
        </div>
    </div>
    <div id="start-screen">
        <h1>🔥 TURBO STRIKE</h1>
        <p>Pro Car Shooter • Avoid or Destroy Enemy Cars</p>
        <p>Use Arrow Keys / WASD + Click or SPACE to Shoot</p>
        <button class="start-btn" onclick="startGame()">START GAME</button>
    </div>
    <div id="game-over">
        <h1>GAME OVER</h1>
        <p id="final-score">Score: 0</p>
        <button class="start-btn" onclick="restartGame()">PLAY AGAIN</button>
    </div>

    <script>
        const canvas = document.getElementById('game-canvas');
        const ctx = canvas.getContext('2d');

        const ROAD_WIDTH = 350;
        const ROAD_LEFT = (canvas.width - ROAD_WIDTH) / 2;
        const LANE_W = ROAD_WIDTH / 3;

        let gameRunning = false;
        let score = 0;
        let lives = 3;
        let ammo = 50;
        let roadOffset = 0;

        let player = {
            x: canvas.width / 2 - 30,
            y: canvas.height - 120,
            w: 60,
            h: 100,
            lane: 1
        };

        let enemies = [];
        let bullets = [];
        let explosions = [];
        let keys = {};

        function spawnEnemy() {
            if (!gameRunning || Math.random() > 0.02) return;
            const lane = Math.floor(Math.random() * 3);
            enemies.push({
                x: ROAD_LEFT + lane * LANE_W + (LANE_W - 50) / 2,
                y: -80,
                w: 50,
                h: 90,
                lane,
                color: `hsl(${Math.random() * 60 + 200}, 70%, 50%)`
            });
        }

        function drawRoad() {
            ctx.fillStyle = '#2d3436';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = '#636e72';
            ctx.fillRect(ROAD_LEFT, 0, ROAD_WIDTH, canvas.height);

            for (let i = -1; i < 20; i++) {
                const y = (i * 45 + roadOffset) % (canvas.height + 50) - 25;
                ctx.fillStyle = '#fdcb6e';
                ctx.fillRect(ROAD_LEFT + ROAD_WIDTH / 2 - 4, y, 8, 30);
            }
            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 2;
            for (let l = 1; l < 3; l++) {
                const x = ROAD_LEFT + l * LANE_W;
                for (let i = -1; i < 25; i++) {
                    const y = (i * 20 + roadOffset * 0.8) % (canvas.height + 40) - 20;
                    ctx.beginPath();
                    ctx.moveTo(x, y);
                    ctx.lineTo(x, y + 12);
                    ctx.stroke();
                }
            }
        }

        function drawCar(x, y, w, h, color, isPlayer) {
            ctx.save();
            ctx.translate(x + w / 2, y + h / 2);
            ctx.translate(-w / 2, -h / 2);

            ctx.shadowColor = color;
            ctx.shadowBlur = 15;
            ctx.fillStyle = color;
            ctx.fillRect(5, 0, w - 10, h);
            ctx.fillRect(0, 15, w, h - 30);

            ctx.fillStyle = 'rgba(200,230,255,0.6)';
            ctx.fillRect(15, 15, 25, 35);

            ctx.fillStyle = '#ffeaa7';
            ctx.beginPath();
            ctx.arc(15, h - 15, 8, 0, Math.PI * 2);
            ctx.arc(w - 15, h - 15, 8, 0, Math.PI * 2);
            ctx.fill();

            if (isPlayer) {
                ctx.fillStyle = '#ff6b6b';
                ctx.fillRect(w / 2 - 15, -5, 30, 15);
            }
            ctx.restore();
        }

        function drawExplosion(ex) {
            const alpha = 1 - (Date.now() - ex.t) / 400;
            if (alpha <= 0) return false;
            ctx.save();
            ctx.globalAlpha = alpha;
            ctx.fillStyle = '#ff6b6b';
            ctx.beginPath();
            ctx.arc(ex.x, ex.y, ex.r + 20, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = '#ffeaa7';
            ctx.beginPath();
            ctx.arc(ex.x, ex.y, ex.r, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
            return true;
        }

        function update() {
            if (!gameRunning) return;

            roadOffset += 8;

            if (keys['ArrowLeft'] || keys['a']) {
                player.lane = Math.max(0, player.lane - 1);
            }
            if (keys['ArrowRight'] || keys['d']) {
                player.lane = Math.min(2, player.lane + 1);
            }
            player.x += (ROAD_LEFT + player.lane * LANE_W + (LANE_W - player.w) / 2 - player.x) * 0.2;

            spawnEnemy();

            for (let e of enemies) {
                e.y += 5;
            }
            enemies = enemies.filter(e => e.y < canvas.height + 50);

            for (let b of bullets) {
                b.y -= 12;
            }
            bullets = bullets.filter(b => b.y > -10);

            for (let b of bullets) {
                for (let i = enemies.length - 1; i >= 0; i--) {
                    const e = enemies[i];
                    if (b.x + 5 > e.x && b.x - 5 < e.x + e.w && b.y < e.y + e.h && b.y > e.y) {
                        explosions.push({ x: e.x + e.w / 2, y: e.y + e.h / 2, r: 20, t: Date.now() });
                        enemies.splice(i, 1);
                        bullets.splice(bullets.indexOf(b), 1);
                        score += 100;
                        break;
                    }
                }
            }

            explosions = explosions.filter(e => drawExplosion(e));

            for (let e of enemies) {
                if (e.y + e.h > player.y && e.y < player.y + player.h &&
                    e.x + e.w > player.x + 15 && e.x < player.x + player.w - 15) {
                    lives--;
                    enemies = enemies.filter(en => en !== e);
                    if (lives <= 0) {
                        gameOver();
                    }
                }
            }

            if (enemies.every(e => e.y + e.h < player.y - 20)) {
                score += 1;
            }

            document.getElementById('score').innerHTML = 'SCORE: <span>' + score + '</span>';
            document.getElementById('lives').innerHTML = 'LIVES: <span>' + lives + '</span>';
            document.getElementById('ammo').innerHTML = 'AMMO: <span>' + ammo + '</span>';
        }

        function shoot() {
            if (!gameRunning || ammo <= 0) return;
            ammo--;
            bullets.push({
                x: player.x + player.w / 2 - 3,
                y: player.y
            });
        }

        function draw() {
            drawRoad();

            for (let e of enemies) {
                drawCar(e.x, e.y, e.w, e.h, e.color, false);
            }
            for (let b of bullets) {
                ctx.fillStyle = '#ffeaa7';
                ctx.fillRect(b.x, b.y, 6, 15);
            }
            drawCar(player.x, player.y, player.w, player.h, '#e94560', true);

            update();
        }

        function gameOver() {
            gameRunning = false;
            document.getElementById('game-over').style.display = 'flex';
            document.getElementById('final-score').textContent = 'Score: ' + score;
        }

        function startGame() {
            document.getElementById('start-screen').style.display = 'none';
            gameRunning = true;
            score = 0;
            lives = 3;
            ammo = 50;
            enemies = [];
            bullets = [];
            explosions = [];
        }

        function restartGame() {
            document.getElementById('game-over').style.display = 'none';
            startGame();
        }

        document.addEventListener('keydown', e => {
            keys[e.key] = true;
            if (e.key === ' ') { e.preventDefault(); shoot(); }
        });
        document.addEventListener('keyup', e => { keys[e.key] = false; });

        document.getElementById('left').addEventListener('click', () => { player.lane = Math.max(0, player.lane - 1); });
        document.getElementById('right').addEventListener('click', () => { player.lane = Math.min(2, player.lane + 1); });
        document.getElementById('shoot').addEventListener('click', shoot);

        document.getElementById('game-canvas').addEventListener('click', (e) => {
            if (gameRunning && e.target.id === 'game-canvas') shoot();
        });

        function gameLoop() {
            draw();
            requestAnimationFrame(gameLoop);
        }
        gameLoop();
    </script>
</body>
</html>
'''

@app.route('/')
def index():
    return render_template_string(HTML)

def open_browser():
    webbrowser.open('http://127.0.0.1:5000')

if __name__ == '__main__':
    threading.Timer(1.2, open_browser).start()
    app.run(debug=False, port=5000, use_reloader=False)
