
# paranthesis - () ,   {} cp   , [] sp


#  )(  - x    }{  - x   ][  - x


s = input("Enter brackets : ")


stack = []

mapping = {")" : "(", "}" : "{", "]" : "["}          # ()    )(

for char in s:
    if char in mapping.values():
        stack.append(char)

    elif char in mapping.keys():
        if not stack or stack[-1] != mapping[char]:
            print("Invalid")
            break
        stack.pop()

else:
    if not stack:
        print("Valid")
    else:
        print("Invalid")

