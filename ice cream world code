    <!-- CUSTOMER CARE MODAL -->
    <div onclick="if(event.target.id === 'care-modal')hideCustomerCare()"
         id="care-modal"
         class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-[10000]">
        <div onclick="event.stopImmediatePropagation()"
             class="bg-white w-full max-w-lg rounded-3xl modal p-8">
            <h2 class="text-4xl mb-6 flex items-center gap-3">💬 Talk to our Ice Cream Angels</h2>

