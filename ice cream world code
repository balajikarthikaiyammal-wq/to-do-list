            <div class="text-8xl mb-6">🎉</div>
            <h2 class="text-5xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-yellow-400 mb-4">Order Placed!</h2>
            <p id="success-text" class="text-2xl mb-8"></p>

            <div class="text-lg mb-8">Your ice cream is on its way! Track it in the app or just wait for the happy knock 🍦</div>

            <button onclick="hideSuccess()"
                    class="px-12 py-6 bg-gradient-to-r from-pink-400 to-yellow-400 text-white text-2xl rounded-3xl">
                BACK TO SCOOPING 🍨
            </button>

            <div class="mt-8 text-pink-400 text-sm">Order ID: <span id="order-id-display" class="font-mono"></span></div>
        </div>
    </div>

    <script>
        // Tailwind initialization
        function initializeTailwind() {
            return {
                config(userConfig = {}) {
                    return {
                        content: [],
                        theme: {
                            extend: {},
                        },
                        plugins: [],
                        ...userConfig,
                    }
                },
                theme(userTheme = {}) {
                    return {
                        ...this.defaultTheme(),
                        ...userTheme,
                    }
                },
                defaultTheme() {
                    return {
                        extend: {
                            colors: {
                                primary: '#ff69b4'
                            }
                        }
                    }
                }
            }
        }

        // Global data
        let products = []
        let cart = []

        // Create beautiful moving clouds + ice cream drops
        function createSkyAnimation() {
            const container = document.getElementById('clouds-container')

            // Create 12 big clouds
            for (let i = 0; i < 12; i++) {
                const cloud = document.createElement('div')
                cloud.className = 'cloud text-8xl'
                cloud.textContent = '☁️'
                cloud.style.top = Math.random() * 65 + '%'
                cloud.style.fontSize = (60 + Math.random() * 50) + 'px'
                cloud.style.animationDuration = (15 + Math.random() * 25) + 's'
                cloud.style.animationDelay = '-' + Math.random() * 30 + 's'
                container.appendChild(cloud)

