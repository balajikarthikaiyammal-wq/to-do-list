<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ice Cream World 🍦</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&amp;family=Playfair+Display:wght@700&amp;display=swap');

        :root {
            --tw-color-primary: #ff69b4;
        }

        * {
            transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 150ms;
        }

        body {
            font-family: 'Poppins', sans-serif;
        }

        .heading-font {
            font-family: 'Playfair Display', sans-serif;
        }

        /* Sky background with moving clouds */
        .sky-bg {
            background: linear-gradient(180deg, #a5f3fc 0%, #ffffff 70%);
            position: relative;
            overflow: hidden;
        }

        .cloud {
            position: absolute;
            color: #fff;
            text-shadow: 0 10px 20px rgba(255,255,255,0.8);
            animation: drift linear infinite;
            user-select: none;
            z-index: 1;
            filter: drop-shadow(0 10px 15px rgba(165, 243, 252, 0.6));
        }

        @keyframes drift {
            from {
                transform: translateX(-150%);
            }
            to {
                transform: translateX(300vw);
            }
        }

        /* Ice cream floating from clouds */
        .ice-drop {
            position: absolute;
            font-size: 2rem;
            animation: iceDrop 8s linear infinite;
            z-index: 2;
            opacity: 0;
        }

        @keyframes iceDrop {
            0% {
                transform: translateY(-100px) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(800px) rotate(720deg);
                opacity: 0;
            }
        }

        .hero-ice {
            animation: floatIce 3s ease-in-out infinite;
        }

        .product-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .product-card:hover {
            transform: scale(1.08) rotate(2deg);
            box-shadow: 25px 25px 30px -10px rgb(249 115 22);
        }

        .cart-bounce {
            animation: cartBounce 0.6s ease;
        }

        .modal {
            animation: modalPop 0.3s ease forwards;
        }

        @keyframes modalPop {
            0% { transform: scale(0.95); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }

        .flavour-badge {
            animation: rainbow 4s linear infinite;
        }
    </style>
</head>
<body class="sky-bg min-h-screen text-gray-800">
