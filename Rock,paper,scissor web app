score = {
    "wins": 0,
    "losses": 0,
    "ties": 0,
    "rounds": 0,
}


def evaluate_round(player_move: str, computer_move: str) -> tuple[str, str]:
    if player_move == computer_move:
        return "tie", "It's a tie."
    if WIN_RULES[player_move] == computer_move:
        return "win", "You win this round!"
    return "lose", "Computer wins this round."


@app.get("/")
def home():
    return render_template_string(PAGE)


@app.post("/play")
def play():
    data = request.get_json(silent=True) or {}
    player_move = str(data.get("move", "")).lower()

    if player_move not in MOVES:
        return jsonify({"error": "Choose rock, paper, or scissors."}), 400

    computer_move = choice(MOVES)
    result, message = evaluate_round(player_move, computer_move)

    score["rounds"] += 1
    if result == "win":
        score["wins"] += 1
    elif result == "lose":
        score["losses"] += 1
    else:
        score["ties"] += 1

    return jsonify(
        {
            "player_move": player_move,
            "computer_move": computer_move,
            "result": result,
            "message": message,
            "score": score,
        }
    )


@app.post("/reset")
def reset():
    score["wins"] = 0
    score["losses"] = 0
    score["ties"] = 0
    score["rounds"] = 0
    return jsonify({"message": "Score reset.", "score": score})


if __name__ == "__main__":
    app.run(debug=True)

