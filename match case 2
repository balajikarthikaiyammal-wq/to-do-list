
def calculator(a, b, op):
    match op:
        case "+":
            return a + b
        case "-":
            return a - b
        case "*":
            return a * b
        case "/":
            if b == 0:
                return "Division by zero is not possible"
            return a / b
        case __:
            return "Invalid operator"
print(calculator(10, 5, "+"))
