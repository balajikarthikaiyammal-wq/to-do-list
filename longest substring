def longest_substring(s):


    char_set = set()

    left = 0

    max_length = 0

    for right in range(len(s)):

        while s[right] in char_set:
            char_set.remove(s[left])     # a-3   0-a
            left += 1

        char_set.add(s[right])

        max_length = max(max_length, right - left + 1)     #  "abcabccb"    0-a   a- char_set - append       b - char_set  c - 2


    return max_length     #   a - 3     bca        abca        abcc   x =


print(longest_substring("abcabccb"))





