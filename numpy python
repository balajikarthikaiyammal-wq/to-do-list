
# numpy - numerical python
# program 1

import numpy as np


arr = np.array([10, 20, 30, 40])

print("original array : ", arr)

print("array + 5 : ", arr + 5)


print("array * 2 : ", arr * 2)

print("array square : ", arr ** 2)



