import numpy as np

A = np.array([[1, 2], [3, 4]])

B = np.array([[5, 6], [7, 8]])


print("matrix A : ", A)

print("matrix B : ", B)


print("addition :  ", A + B)

print("subtraction  : ", A - B)


print("matrix mul : ", np.dot(A, B))













