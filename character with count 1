def first_non_repeated_char(s):

    char_count = {}

    for char in s:
        if char in char_count:
            char_count[char] += 1
        else:
            char_count[char] = 1


    for char in s:
        if char_count[char] == 1:
            return char

    return None



input_string = "programming"

result = first_non_repeated_char(input_string)

if result:
    print("First nonrepeated character : ", result)

else:
    print("No nonrepeating characters found")
