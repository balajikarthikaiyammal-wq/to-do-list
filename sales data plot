import numpy as np

import matplotlib.pyplot as plt

products = ["Laptop", "Mobile", "Tablet", "Headphones", "smartwatch"]


sales = np.array([120, 200, 90, 150, 80])


plt.bar(products, sales)

plt.title("Product sales analysis")

plt.xlabel("products")

plt.ylabel("sales units")


plt.grid(axis = 'y')


plt.show()





