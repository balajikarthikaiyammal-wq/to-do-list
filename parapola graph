# parabola graph plotting


import numpy as np

import matplotlib.pyplot as plt

x = np.linspace(-10, 10, 100)   # 10-(-10)  = 10 + 10 = 20  - 20 /100 = 0.2   -10 , -9.8, -9.6, -9.4 ...........   + 10     linspace()

y = x ** 2

plt.plot(x, y)

plt.title("Graph of y = x ^ 2")
plt.xlabel("X values")
plt.ylabel("Y label")

plt.grid()

plt.show()

